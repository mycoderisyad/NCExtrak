<?xml version="1.0"?>
<info xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:noNamespaceSchemaLocation="https://apps.nextcloud.com/schema/apps/info.xsd">
	<id>ncextrak</id>
	<name>NCExtrak</name>
	<summary>Extract archives directly from Nextcloud Files</summary>
	<description>Extract supported archives directly from the Files context menu.</description>
	<version>0.1.4</version>
	<licence>AGPL-3.0-only</licence>
	<author homepage="https://github.com/mycoderisyad">mycoderisyad</author>
	<namespace>NCExtrak</namespace>
	<category>files</category>
	<website>https://github.com/mycoderisyad/NCExtrak</website>
	<bugs>https://github.com/mycoderisyad/NCExtrak/issues</bugs>
	<repository type="git">https://github.com/mycoderisyad/NCExtrak.git</repository>
	<dependencies>
		<php min-version="8.2"/>
		<nextcloud min-version="30" max-version="33"/>
