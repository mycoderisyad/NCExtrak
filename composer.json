{
  "name": "ncextrak/ncextrak",
  "description": "Archive extraction app for Nextcloud",
  "type": "project",
  "license": "AGPL-3.0-only",
  "require": {
    "php": ">=8.2",
    "ext-json": "*",
    "symfony/process": "^7.2"
  },
  "require-dev": {
    "nextcloud/ocp": "^33.0",
    "phpstan/phpstan": "^2.1",
    "friendsofphp/php-cs-fixer": "^3.88"
  },
  "autoload": {
    "psr-4": {
      "OCA\\NCExtrak\\": "lib/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "OCA\\NCExtrak\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "lint": "php-cs-fixer fix --dry-run --diff --config=.php-cs-fixer.dist.php",
    "format": "php-cs-fixer fix --config=.php-cs-fixer.dist.php"
  },
  "config": {
    "sort-packages": true,
    "platform": {
      "php": "8.2.31"
    }
  }
}
